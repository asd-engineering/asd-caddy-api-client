        },
        "ui": {
          "type": "object",
          "properties": {
            "theme": {
              "type": "string"
            },
            "logo_url": {
              "type": "string"
            },
            "custom_css": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "cookie_config": {
          "type": "object",
          "properties": {
            "domains": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "lifetime": {
                    "type": "number"
                  },
                  "insecure": {
                    "type": "boolean"
                  },
                  "same_site": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            },
            "path": {
              "type": "string"
            },
            "lifetime": {
              "type": "number"
            },
            "insecure": {
              "type": "boolean"
            },
            "same_site": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "identity_stores": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "identity_providers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "user_transformer_configs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": {}
          }
