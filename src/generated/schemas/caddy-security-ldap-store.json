{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://asd-engineering.github.io/asd-caddy-api-client/schemas/caddy-security-ldap-store.json",
  "title": "Caddy Security Ldap Store",
  "description": "caddy-security LDAP identity store configuration",
  "$ref": "#/definitions/caddy-security-ldap-store",
  "definitions": {
    "caddy-security-ldap-store": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "const": "ldap"
        },
        "params": {
          "type": "object",
          "properties": {
            "realm": {
              "type": "string"
            },
            "servers": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "address": {
                    "type": "string"
                  },
                  "port": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 65535
                  }
                },
                "required": ["address"],
                "additionalProperties": false
              }
            },
            "bind_username": {
              "type": "string"
            },
            "bind_password": {
              "type": "string"
            },
            "search_base_dn": {
              "type": "string"
            },
            "search_user_filter": {
              "type": "string"
            },
            "groups": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "dn": {
                    "type": "string"
                  },
                  "roles": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": ["dn"],
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": true
        }
      },
      "required": ["name", "kind", "params"],
      "additionalProperties": false
    }
  }
}
