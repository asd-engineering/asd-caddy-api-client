{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://asd-engineering.github.io/asd-caddy-api-client/schemas/caddy-security-policy.json",
  "title": "Caddy Security Policy",
  "description": "caddy-security authorization policy (gatekeeper) configuration",
  "$ref": "#/definitions/caddy-security-policy",
  "definitions": {
    "caddy-security-policy": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "access_list_rules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "comment": {
                "type": "string"
              },
              "conditions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "action": {
                "type": "string",
                "enum": ["allow", "deny"]
              }
            },
            "additionalProperties": false
          }
        },
        "crypto_key_configs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "token_name": {
                "type": "string"
              },
              "source": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "bypass_configs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "match_type": {
                "type": "string"
              },
              "uri": {
                "type": "string"
              }
            },
            "required": ["match_type"],
            "additionalProperties": false
          }
        }
      },
      "required": ["name"],
      "additionalProperties": false
    }
  }
}
