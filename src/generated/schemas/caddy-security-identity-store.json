{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://asd-engineering.github.io/asd-caddy-api-client/schemas/caddy-security-identity-store.json",
  "title": "Caddy Security Identity Store",
  "description": "caddy-security identity store (local, LDAP, OAuth2, OIDC)",
  "$ref": "#/definitions/caddy-security-identity-store",
  "definitions": {
    "caddy-security-identity-store": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "const": "local"
            },
            "params": {
              "type": "object",
              "properties": {
                "realm": {
                  "type": "string"
                },
                "path": {
                  "type": "string"
                }
              },
              "required": ["path"],
              "additionalProperties": false
            }
          },
          "required": ["name", "kind", "params"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "const": "ldap"
            },
            "params": {
              "type": "object",
              "properties": {
                "realm": {
                  "type": "string"
                },
                "servers": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "address": {
                        "type": "string"
                      },
                      "port": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "maximum": 65535
                      }
                    },
                    "required": ["address"],
                    "additionalProperties": false
                  }
                },
                "bind_username": {
                  "type": "string"
                },
                "bind_password": {
                  "type": "string"
                },
                "search_base_dn": {
                  "type": "string"
                },
                "search_user_filter": {
                  "type": "string"
                },
                "groups": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "dn": {
                        "type": "string"
                      },
                      "roles": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    },
                    "required": ["dn"],
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": true
            }
          },
          "required": ["name", "kind", "params"],
          "additionalProperties": false
        }
      ]
    }
  }
}
