{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://asd-engineering.github.io/asd-caddy-api-client/schemas/caddy-security-oidc-provider.json",
  "title": "Caddy Security Oidc Provider",
  "description": "caddy-security OIDC identity provider configuration",
  "$ref": "#/definitions/caddy-security-oidc-provider",
  "definitions": {
    "caddy-security-oidc-provider": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "const": "oauth"
        },
        "params": {
          "type": "object",
          "properties": {
            "driver": {
              "type": "string"
            },
            "realm": {
              "type": "string"
            },
            "client_id": {
              "type": "string"
            },
            "client_secret": {
              "type": "string"
            },
            "metadata_url": {
              "type": "string"
            },
            "scopes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        }
      },
      "required": ["name", "kind", "params"],
      "additionalProperties": false
    }
  }
}
