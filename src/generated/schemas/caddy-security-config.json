{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://asd-engineering.github.io/asd-caddy-api-client/schemas/caddy-security-config.json",
  "title": "Caddy Security Config",
  "description": "caddy-security configuration (portals, policies, identity stores)",
  "$ref": "#/definitions/caddy-security-config",
  "definitions": {
    "caddy-security-config": {
      "type": "object",
      "properties": {
        "authentication_portals": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "ui": {
                "type": "object",
                "properties": {
                  "theme": {
                    "type": "string"
                  },
                  "logo_url": {
                    "type": "string"
                  },
                  "custom_css": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              },
              "cookie_config": {
                "type": "object",
                "properties": {
                  "domains": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "object",
                      "properties": {
                        "lifetime": {
                          "type": "number"
                        },
                        "insecure": {
                          "type": "boolean"
                        },
                        "same_site": {
                          "type": "string"
                        }
                      },
                      "additionalProperties": false
                    }
                  },
                  "path": {
                    "type": "string"
                  },
                  "lifetime": {
                    "type": "number"
                  },
                  "insecure": {
                    "type": "boolean"
                  },
                  "same_site": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              },
              "identity_stores": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "identity_providers": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "user_transformer_configs": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": {}
                }
              }
            },
            "required": ["name"],
            "additionalProperties": false
          }
        },
        "authorization_policies": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "access_list_rules": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "comment": {
                      "type": "string"
                    },
                    "conditions": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "action": {
                      "type": "string",
                      "enum": ["allow", "deny"]
                    }
                  },
                  "additionalProperties": false
                }
              },
              "crypto_key_configs": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "token_name": {
                      "type": "string"
                    },
                    "source": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": false
                }
              },
              "bypass_configs": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "match_type": {
                      "type": "string"
                    },
                    "uri": {
                      "type": "string"
                    }
                  },
                  "required": ["match_type"],
                  "additionalProperties": false
                }
              }
            },
            "required": ["name"],
            "additionalProperties": false
          }
        },
        "credentials": {
          "type": "object",
          "properties": {
            "generic": {
              "type": "object",
              "additionalProperties": {}
            }
          },
          "additionalProperties": false
        },
        "identity_stores": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "kind": {
                    "type": "string",
                    "const": "local"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "realm": {
                        "type": "string"
                      },
                      "path": {
                        "type": "string"
                      }
                    },
                    "required": ["path"],
                    "additionalProperties": false
                  }
                },
                "required": ["name", "kind", "params"],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "kind": {
                    "type": "string",
                    "const": "ldap"
                  },
                  "params": {
                    "type": "object",
                    "properties": {
                      "realm": {
                        "type": "string"
                      },
                      "servers": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "address": {
                              "type": "string"
                            },
                            "port": {
                              "type": "integer",
                              "exclusiveMinimum": 0,
                              "maximum": 65535
                            }
                          },
                          "required": ["address"],
                          "additionalProperties": false
                        }
                      },
                      "bind_username": {
                        "type": "string"
                      },
                      "bind_password": {
                        "type": "string"
                      },
                      "search_base_dn": {
                        "type": "string"
                      },
                      "search_user_filter": {
                        "type": "string"
                      },
                      "groups": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "dn": {
                              "type": "string"
                            },
                            "roles": {
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            }
                          },
                          "required": ["dn"],
                          "additionalProperties": false
                        }
                      }
                    },
                    "additionalProperties": true
                  }
                },
                "required": ["name", "kind", "params"],
                "additionalProperties": false
              }
            ]
          }
        },
        "identity_providers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "kind": {
                "type": "string",
                "const": "oauth"
              },
              "params": {
                "anyOf": [
                  {
                    "type": "object",
                    "properties": {
                      "driver": {
                        "type": "string"
                      },
                      "realm": {
                        "type": "string"
                      },
                      "client_id": {
                        "type": "string"
                      },
                      "client_secret": {
                        "type": "string"
                      },
                      "scopes": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "authorization_url": {
                        "type": "string"
                      },
                      "token_url": {
                        "type": "string"
                      }
                    },
                    "additionalProperties": true
                  },
                  {
                    "type": "object",
                    "properties": {
                      "driver": {
                        "type": "string"
                      },
                      "realm": {
                        "type": "string"
                      },
                      "client_id": {
                        "type": "string"
                      },
                      "client_secret": {
                        "type": "string"
                      },
                      "metadata_url": {
                        "type": "string"
                      },
                      "scopes": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    },
                    "additionalProperties": true
                  }
                ]
              }
            },
            "required": ["name", "kind", "params"],
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  }
}
